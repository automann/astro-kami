---
import PostArchivePage from "@/components/pages/PostArchivePage.astro";
import { getPostsForLocale, sortMDByDate } from "@/data/post";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
	const posts = sortMDByDate(await getPostsForLocale("zh"));
	return paginate(posts, { pageSize: 1000 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<PostArchivePage locale="zh" page={page} />
