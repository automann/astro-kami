---
import TagArchivePage from "@/components/pages/TagArchivePage.astro";
import { getPostsByTag, getPostsForLocale, getUniqueTags, sortMDByDate } from "@/data/post";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async () => {
	const posts = sortMDByDate(await getPostsForLocale("zh"));
	return getUniqueTags(posts).map((tag) => ({
		params: { tag },
		props: { posts: getPostsByTag(posts, tag), tag },
	}));
}) satisfies GetStaticPaths;

const { posts, tag } = Astro.props;
---

<TagArchivePage locale="zh" posts={posts} tag={tag} />
