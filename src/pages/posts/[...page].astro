---
import PostArchivePage from "@/components/pages/PostArchivePage.astro";
import { getPostsForLocale, sortMDByDate } from "@/data/post";
import type { GetStaticPaths } from "astro";

export const getStaticPaths = (async ({ paginate }) => {
	const posts = sortMDByDate(await getPostsForLocale("en"));
	return paginate(posts, { pageSize: 20 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<PostArchivePage locale="en" page={page} />
