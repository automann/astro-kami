---
import type { CollectionEntry } from "astro:content";
import { getPostSlug, getPostSortDate } from "@/data/post";
import { localizedPath, type Locale } from "@/i18n/config";
import { formatRailDate } from "@/utils/date";
import { withBase } from "@/utils/path";

interface Props {
	posts: CollectionEntry<"post">[];
	/** Seeds the `--i` stagger-animation index (e.g. when rows follow a featured post). */
	startIndex?: number;
	/** Heading tag for each post title. */
	headingLevel?: "h2" | "h3";
	locale: Locale;
}

const { posts, locale, startIndex = 0, headingLevel = "h2" } = Astro.props;
const Heading = headingLevel;
---

{
	posts.map((p, idx) => (
		<a
			class="post"
			data-astro-prefetch
				href={withBase(localizedPath(locale, `/posts/${getPostSlug(p)}/`))}
			style={`--i: ${startIndex + idx}`}
		>
			<div class="post-rail">
				<time class="post-date" datetime={getPostSortDate(p).toISOString()}>
					{formatRailDate(getPostSortDate(p), locale)}
				</time>
				<span class="post-dot" aria-hidden="true" />
			</div>
			<div class="post-body">
				<Heading class="post-title">{p.data.title}</Heading>
				<p class="post-preview">{p.data.description}</p>
			</div>
		</a>
	))
}
