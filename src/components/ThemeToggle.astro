---
import { messages, type Locale } from "@/i18n/config";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const theme = messages[locale].theme;
---

<button class="theme-toggle" id="theme-toggle" type="button" aria-label={theme.toggle}>
	<span class="icon" aria-hidden="true"></span>
	<span class="label label-dark">{theme.dark}</span>
	<span class="label label-light">{theme.light}</span>
</button>

<style is:global>
	.theme-toggle {
		display: inline-block;
		padding: 6px 12px;
		border-radius: 999px;
		background: var(--accent-soft);
		color: hsl(var(--theme-text-muted));
		border: 1px solid transparent;
		font-family: var(--font-sans);
		font-size: 12px;
		font-weight: 500;
		line-height: 1.4;
		cursor: pointer;
		transition: background 0.2s ease, color 0.2s ease;
	}
	.theme-toggle:hover {
		background: var(--accent-soft-strong);
		color: hsl(var(--theme-accent));
	}
	.theme-toggle:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
	}

	.theme-toggle .icon {
		display: inline-block;
		width: 1em;
		font-size: 13px;
		margin-right: 6px;
		text-align: center;
		transform: translateY(-1px);
	}
	.theme-toggle .icon::before { content: "☾"; }
	[data-theme="dark"] .theme-toggle .icon::before { content: "☀"; }

	.theme-toggle .label {
		display: inline-block;
		min-width: 2.6em;
		text-align: left;
	}
	.theme-toggle .label-light { display: none; }
	[data-theme="dark"] .theme-toggle .label-dark { display: none; }
	[data-theme="dark"] .theme-toggle .label-light { display: inline-block; }
</style>

<script>
	const r = document.documentElement;
	const btn = document.getElementById("theme-toggle") as HTMLButtonElement | null;
	if (btn) {
		btn.addEventListener("click", () => {
			const next = r.dataset.theme === "dark" ? "light" : "dark";
			r.dataset.theme = next;
			try { localStorage.setItem("theme", next); } catch {}
			document.dispatchEvent(new CustomEvent("theme-change", { detail: { theme: next } }));
		});
	}
</script>
