---
import type { ShowcaseBadge } from "@/data/showcase";

interface Props {
	badge: ShowcaseBadge;
}

const { badge } = Astro.props;
---

<span class="badge">
	{
		badge.icon === "star" && (
			<svg
				aria-hidden="true"
				viewBox="0 0 16 16"
				fill="currentColor"
				focusable="false"
			>
				<path d="m8 1.75 1.86 3.77 4.16.6-3.01 2.94.71 4.14L8 11.26 4.28 13.2l.71-4.14-3.01-2.94 4.16-.6L8 1.75Z" />
			</svg>
		)
	}
	<span>{badge.label}</span>
</span>
