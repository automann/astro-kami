---
import PostList from "@/components/blog/PostList.astro";
import ShowcaseBadge from "@/components/showcase/ShowcaseBadge.astro";
import { getPostSlug, getPostSortDate, getPostsForLocale, sortMDByDate } from "@/data/post";
import { getFeaturedShowcase, showcase } from "@/data/showcase";
import { defaultLocale, localizedPath, messages, type Locale } from "@/i18n/config";
import PageLayout from "@/layouts/Base.astro";
import { siteConfig } from "@/site-config";
import { formatRailDate, formatStampDate } from "@/utils/date";
import { absoluteUrl, withBase } from "@/utils/path";
import { Schema } from "astro-seo-schema";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = messages[locale];
const description = locale === defaultLocale ? siteConfig.description : t.homeDescription;
const allPosts = await getPostsForLocale(locale);
const allPostsByDate = sortMDByDate(allPosts);
const TIMELINE_LIMIT = 5;
const timelinePosts = allPostsByDate.slice(0, TIMELINE_LIMIT);
const featured = timelinePosts[0];
const rest = timelinePosts.slice(1);
const archiveCount = allPosts.length;
const featuredShowcase = getFeaturedShowcase();

const profile = siteConfig.profile;
const siteUrl = (path: string) => absoluteUrl(path, Astro.site);
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: t.nav["/"],
				item: siteUrl(localizedPath(locale, "/")),
			},
			{
				"@type": "ListItem",
				position: 2,
				name: t.nav["/about/"],
				item: siteUrl("/about"),
			},
			{
				"@type": "ListItem",
				position: 3,
				name: t.nav["/posts/"],
				item: siteUrl(localizedPath(locale, "/posts")),
			},
		],
	}}
/>

	<PageLayout locale={locale} meta={{ alternatePath: "/", title: t.nav["/"], description }}>
	<section class="hero">
		<p>{description}</p>
		<div class="socials">
			{profile?.github && (
				<>
					<a href={profile.github} rel="noreferrer" target="_blank">GitHub</a>
					<span class="sep">·</span>
				</>
			)}
			{profile?.linkedin && (
				<>
					<a href={profile.linkedin} rel="noreferrer" target="_blank">LinkedIn</a>
					<span class="sep">·</span>
				</>
			)}
			{profile?.email && (
				<>
					<a href={`mailto:${profile.email}`}>Email</a>
					<span class="sep">·</span>
				</>
			)}
			<a href={withBase(localizedPath(locale, "/rss.xml"))}>RSS</a>
		</div>
	</section>

	<section class="writing" aria-labelledby="writing-label">
		<div class="section-label" id="writing-label">{t.writing}</div>
		<div class="timeline">
			{
				featured && (
					<div class="post featured" style="--i: 0">
						<div class="post-rail">
							<time class="post-date" datetime={getPostSortDate(featured).toISOString()}>
								{formatRailDate(getPostSortDate(featured), locale)}
							</time>
							<span class="post-dot" aria-hidden="true" />
						</div>
						<div class="post-body">
							<div class="post-stamp">{t.latest} · {formatStampDate(getPostSortDate(featured), locale)}</div>
							<h2 class="post-title">
								<a class="post-cardlink" data-astro-prefetch href={withBase(localizedPath(locale, `/posts/${getPostSlug(featured)}/`))}>
									{featured.data.title}
								</a>
							</h2>
							<p class="post-excerpt">{featured.data.description}</p>
							{!!featured.data.tags?.length && (
								<div class="post-meta">
									{featured.data.tags.map((t, i) => (
										<Fragment>
											{i > 0 && <span class="dot">·</span>}
										<a class="tag" href={withBase(localizedPath(locale, `/tags/${encodeURIComponent(t)}/`))}>{t}</a>
										</Fragment>
									))}
								</div>
							)}
						</div>
					</div>
				)
			}

			<PostList posts={rest} locale={locale} startIndex={1} headingLevel="h3" />

			<div class="view-all-link posts-link" style={`--i: ${rest.length + 1}`}>
				<a data-astro-prefetch href={withBase(localizedPath(locale, "/posts/"))}
					>{t.viewAllPosts(archiveCount)}</a
				>
			</div>
		</div>
	</section>

	{showcase.length > 0 && (
		<section class="work" aria-labelledby="work-label">
			<div class="section-label" id="work-label">{t.showcase}</div>
			<ul class="work-list">
				{featuredShowcase.map((item, idx) => (
					<li style={`--i: ${idx + 1}`}>
						<a href={item.href} rel="noreferrer" target="_blank">
							<div class="head">
								<span class="name">{item.name}</span>
								<span class="stack">{item.stack}</span>
								{item.badge && <ShowcaseBadge badge={item.badge} />}
							</div>
							<p>{item.desc[locale]}</p>
						</a>
					</li>
				))}
			</ul>
			<div class="view-all-link showcase-link" style={`--i: ${featuredShowcase.length + 1}`}>
				<a data-astro-prefetch href={withBase(localizedPath(locale, "/showcase/"))}>
					{t.viewAllProjects(showcase.length)}
				</a>
			</div>
		</section>
	)}
</PageLayout>

<style>
	/* ---------- Hero ---------- */
	.hero {
		margin-bottom: 76px;
	}
	.hero p {
		font-size: 19.5px;
		line-height: 1.65;
		color: hsl(var(--theme-text));
		margin: 0 0 22px;
		max-width: 60ch;
		text-wrap: pretty;
		white-space: pre-line;
	}
	.socials {
		font-family: var(--font-sans);
		font-size: 13.5px;
		color: hsl(var(--theme-text) / 0.72);
		margin-top: 18px;
	}
	.socials a {
		color: hsl(var(--theme-text-muted));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.socials a:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}
	.socials .sep {
		color: var(--faint);
		margin: 0 9px;
	}

	/* ---------- Writing timeline ---------- */
	.writing {
		margin-bottom: 84px;
	}
	/* ---------- Featured post ---------- */
	.post.featured .post-body {
		position: relative;
		padding-bottom: 56px;
	}
	/* Title is the post link; its ::after stretches over the whole card body so
	   clicking anywhere opens the post, while the tag links sit above it. */
	.post.featured .post-cardlink {
		color: inherit;
		text-decoration: none;
	}
	.post.featured .post-cardlink::after {
		content: "";
		position: absolute;
		inset: 0;
		z-index: 1;
	}
	.post.featured .post-cardlink:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}
	.post.featured .post-stamp {
		font-family: var(--font-mono);
		font-size: 11px;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		color: hsl(var(--theme-accent));
		margin-bottom: 12px;
	}
	.post.featured .post-title {
		font-size: 30px;
		line-height: 1.14;
		margin-bottom: 14px;
		letter-spacing: -0.02em;
	}
	.post.featured .post-excerpt {
		font-size: 18px;
		line-height: 1.62;
		color: hsl(var(--theme-text-muted));
		margin: 0 0 14px;
		max-width: 58ch;
		word-wrap: break-word;
		overflow-wrap: anywhere;
	}
	.post.featured .post-meta {
		position: relative;
		z-index: 2;
		font-family: var(--font-mono);
		font-size: 11.5px;
		color: hsl(var(--theme-text) / 0.55);
		font-variant-numeric: tabular-nums;
		font-feature-settings: "tnum";
	}
	.post.featured .post-meta .tag {
		color: inherit;
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.post.featured .post-meta .tag::before {
		content: "#";
		color: var(--faint);
		transition: color 0.2s ease;
	}
	.post.featured .post-meta .tag:hover,
	.post.featured .post-meta .tag:hover::before {
		color: hsl(var(--theme-accent));
	}
	.post.featured .post-meta .tag:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 2px;
		border-radius: 3px;
	}
	.post.featured .post-meta .dot {
		color: var(--faint);
		margin: 0 8px;
	}
	.post.featured .post-dot {
		--rail-dot-size: 11px;
		border-color: hsl(var(--theme-text-muted));
	}
	.post.featured:hover .post-dot {
		background: hsl(var(--theme-accent));
		border-color: hsl(var(--theme-accent));
	}

	.view-all-link {
		font-family: var(--font-sans);
		font-size: 13.5px;
		color: hsl(var(--theme-text) / 0.72);
	}
	.posts-link {
		grid-column: 2;
		margin-top: 8px;
	}
	.showcase-link {
		margin-top: 36px;
	}
	.view-all-link a {
		display: inline-block;
		padding: 6px 0;
		color: hsl(var(--theme-text-muted));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.view-all-link a:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}

	.work {
		margin-bottom: 88px;
	}

	.socials a:focus-visible,
	.view-all-link a:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.hero {
			margin-bottom: 56px;
		}
		.hero p {
			font-size: 18px;
		}
		.post.featured .post-rail {
			display: none;
		}
		.post.featured .post-body {
			padding-bottom: 24px;
			border-bottom: 1px solid var(--hairline);
			margin-bottom: 4px;
		}
		.post.featured .post-title {
			font-size: 22px;
			line-height: 1.2;
			letter-spacing: -0.015em;
			margin-bottom: 10px;
		}
		.post.featured .post-excerpt {
			font-size: 15.5px;
			line-height: 1.55;
			margin: 0 0 10px;
		}
		.post.featured .post-meta {
			font-size: 11px;
		}
		.posts-link {
			margin-top: 0;
		}
	}

	@media (max-width: 420px) {
		.hero {
			margin-bottom: 48px;
		}
		.hero p {
			font-size: 17px;
		}
		.socials {
			font-size: 12.5px;
		}
		.socials .sep {
			margin: 0 6px;
		}
		.writing {
			margin-bottom: 64px;
		}
		.post.featured .post-title {
			font-size: 17px;
		}
		.post.featured .post-excerpt {
			font-size: 15px;
		}
		.work {
			margin-bottom: 56px;
		}
	}
</style>
