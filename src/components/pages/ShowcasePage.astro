---
import ShowcaseBadge from "@/components/showcase/ShowcaseBadge.astro";
import { getShowcaseByPriority } from "@/data/showcase";
import { localizedPath, messages, type Locale } from "@/i18n/config";
import PageLayout from "@/layouts/Base.astro";
import { absoluteUrl } from "@/utils/path";
import { Schema } from "astro-seo-schema";

interface Props {
	locale: Locale;
}

const { locale } = Astro.props;
const t = messages[locale];
const homePath = localizedPath(locale, "/");
const showcasePath = localizedPath(locale, "/showcase/");
const sortedShowcase = getShowcaseByPriority();
---

<Schema
	item={{
		"@context": "https://schema.org",
		"@type": "BreadcrumbList",
		itemListElement: [
			{
				"@type": "ListItem",
				position: 1,
				name: t.nav["/"],
				item: absoluteUrl(homePath, Astro.site),
			},
			{
				"@type": "ListItem",
				position: 2,
				name: t.showcase,
				item: absoluteUrl(showcasePath, Astro.site),
			},
		],
	}}
/>

<PageLayout
	locale={locale}
	meta={{
		alternatePath: "/showcase/",
		title: t.showcase,
		description: t.showcaseDescription,
	}}
>
	<section class="work" aria-labelledby="work-label">
		<div class="section-label" id="work-label">{t.showcase}</div>
		<p class="intro">{t.showcaseDescription}</p>
		<ul class="work-list">
			{
					sortedShowcase.map((item) => (
					<li>
						<a href={item.href} rel="noreferrer" target="_blank">
							<div class="head">
								<span class="name">{item.name}</span>
								<span class="stack">{item.stack}</span>
								{item.badge && <ShowcaseBadge badge={item.badge} />}
							</div>
							<p>{item.desc[locale]}</p>
						</a>
					</li>
				))
			}
		</ul>
	</section>
</PageLayout>

<style>
	.work {
		margin-bottom: 88px;
	}
	.intro {
		font-family: var(--font-serif);
		font-size: 17.5px;
		line-height: 1.7;
		color: hsl(var(--theme-text));
		margin: 0 0 36px;
		max-width: 60ch;
		text-wrap: pretty;
	}

	@media (max-width: 720px) {
		.intro {
			font-size: 17px;
			margin-bottom: 28px;
		}
	}
	@media (max-width: 420px) {
		.work {
			margin-bottom: 56px;
		}
		.intro {
			font-size: 16.5px;
		}
	}
</style>
