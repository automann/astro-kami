---
import type { CollectionEntry } from "astro:content";
import PostList from "@/components/blog/PostList.astro";
import { messages, type Locale } from "@/i18n/config";
import PageLayout from "@/layouts/Base.astro";
import type { Page } from "astro";

interface Props {
	page: Page<CollectionEntry<"post">>;
	locale: Locale;
}

const { locale, page } = Astro.props;
const t = messages[locale];

const meta = {
	alternatePath: "/posts/",
	description: t.postsDescription,
	title: t.posts,
};

const paginationProps = {
	...(page.url.prev && {
		prevUrl: {
				text: locale === "zh" ? "← 上一页" : "← Previous",
			url: page.url.prev,
		},
	}),
	...(page.url.next && {
		nextUrl: {
				text: locale === "zh" ? "下一页 →" : "Next →",
			url: page.url.next,
		},
	}),
};

const totalCount = page.total;
---

<PageLayout locale={locale} meta={meta}>
	<section class="writing" aria-labelledby="writing-label">
		<div class="section-label" id="writing-label">
			{t.writing} · {totalCount} {locale === "zh" ? "篇文章" : "posts"}
		</div>
		<div class="timeline">
			<PostList posts={page.data} locale={locale} />
		</div>
		{
			(paginationProps.prevUrl || paginationProps.nextUrl) && (
				<nav class="pagination" aria-label="Pagination">
					{paginationProps.prevUrl && (
						<a class="pag-link prev" data-astro-prefetch href={paginationProps.prevUrl.url}>
							{paginationProps.prevUrl.text}
						</a>
					)}
					{paginationProps.nextUrl && (
						<a class="pag-link next" data-astro-prefetch href={paginationProps.nextUrl.url}>
							{paginationProps.nextUrl.text}
						</a>
					)}
				</nav>
			)
		}
	</section>
</PageLayout>

<style>
	.writing {
		margin-bottom: 96px;
	}

	.pagination {
		grid-column: 2;
		margin-top: 8px;
		display: flex;
		gap: 24px;
		align-items: center;
		justify-content: space-between;
	}
	.pag-link {
		display: inline-block;
		padding: 8px 4px;
		font-family: var(--font-mono);
		font-size: 11.5px;
		letter-spacing: 0.04em;
		text-transform: uppercase;
		color: hsl(var(--theme-text-muted));
		text-decoration: underline;
		text-decoration-color: hsl(var(--theme-text) / 0.35);
		text-decoration-thickness: 1px;
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.pag-link.prev {
		margin-right: auto;
	}
	.pag-link.next {
		margin-left: auto;
	}
	.pag-link:hover {
		color: hsl(var(--theme-accent));
		text-decoration-color: hsl(var(--theme-accent));
	}
	.pag-link:focus-visible {
		outline: 2px solid hsl(var(--theme-accent));
		outline-offset: 3px;
		border-radius: 3px;
	}

	@media (max-width: 720px) {
		.pagination {
			margin-top: 16px;
		}
	}

	@media (max-width: 420px) {
		.writing {
			margin-bottom: 64px;
		}
	}
</style>
